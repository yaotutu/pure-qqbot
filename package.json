{
  "name": "pure-qqbot",
  "version": "1.0.0",
  "description": "Pure QQ Bot SDK - Independent from OpenClaw framework. Direct WebSocket connection to QQ Bot API.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "qq",
    "bot",
    "sdk",
    "qqbot",
    "websocket",
    "message",
    "chatbot"
  ],
  "author": "yaotutu",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yaotutu/pure-qqbot.git"
  },
  "bugs": {
    "url": "https://github.com/yaotutu/pure-qqbot/issues"
  },
  "homepage": "https://github.com/yaotutu/pure-qqbot#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
